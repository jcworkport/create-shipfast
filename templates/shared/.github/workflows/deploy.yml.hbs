name: Deploy

on:
  push:
    branches: [main]

env:
  AWS_REGION: {{awsRegion}}
  ECR_REGISTRY: ${{ "{{" }} secrets.ECR_REGISTRY {{ "}}" }}

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ "{{" }} secrets.AWS_ACCESS_KEY_ID {{ "}}" }}
          aws-secret-access-key: ${{ "{{" }} secrets.AWS_SECRET_ACCESS_KEY {{ "}}" }}
          aws-region: {{awsRegion}}

      - name: Log in to ECR
        uses: aws-actions/amazon-ecr-login@v2

      {{#if hasBackend}}
      - name: Build and push backend image
        run: |
          IMAGE=$ECR_REGISTRY/{{projectName}}-backend
          docker build -t $IMAGE:$GITHUB_SHA -t $IMAGE:latest ./backend
          docker push $IMAGE:$GITHUB_SHA
          docker push $IMAGE:latest

      - name: Deploy backend to ECS
        run: |
          aws ecs update-service \
            --cluster {{projectName}} \
            --service {{projectName}}-backend \
            --force-new-deployment \
            --region {{awsRegion}}
      {{/if}}

      {{#if hasFrontend}}
      - name: Build and push frontend image
        run: |
          IMAGE=$ECR_REGISTRY/{{projectName}}-frontend
          docker build -t $IMAGE:$GITHUB_SHA -t $IMAGE:latest ./frontend
          docker push $IMAGE:$GITHUB_SHA
          docker push $IMAGE:latest

      - name: Deploy frontend to ECS
        run: |
          aws ecs update-service \
            --cluster {{projectName}} \
            --service {{projectName}}-frontend \
            --force-new-deployment \
            --region {{awsRegion}}
      {{/if}}
