{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "types": ["jest", "node"]
  }
}
