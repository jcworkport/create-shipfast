generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  {{#if isJwt}}passwordHash String{{/if}}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
